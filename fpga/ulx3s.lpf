# ulx3s.lpf — Cartridge Pmod bring-up on the ULX3S 85F
# (sites from the official ulx3s_v20.lpf / v3.1.7 schematic, gpio.sch sheet)
#
# The cartridge plugs into the J1 header END, pins 1-12:
#   J1 pins 1/2 = 3.3V  -> Pmod VCC column
#   J1 pins 3/4 = GND   -> Pmod GND column
#   J1 pins 5-12 = GN0/GP0 .. GN3/GP3 -> Pmod signal columns
# Row orientation (GP vs GN) is autodetected by the bitstream.

LOCATE COMP "clk_25mhz" SITE "G2";
IOBUF  PORT "clk_25mhz" PULLMODE=NONE IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk_25mhz" 25 MHZ;

# btn[0] = PWR (pulled up, press = 0 = reset), btn[1] = fire1 (re-run)
LOCATE COMP "btn[0]" SITE "D6";
LOCATE COMP "btn[1]" SITE "R1";
LOCATE COMP "btn[2]" SITE "T1";
LOCATE COMP "btn[3]" SITE "R18";
LOCATE COMP "btn[4]" SITE "V1";
LOCATE COMP "btn[5]" SITE "U1";
LOCATE COMP "btn[6]" SITE "H16";
IOBUF PORT "btn[0]" PULLMODE=UP   IO_TYPE=LVCMOS33;
IOBUF PORT "btn[1]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[2]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[3]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[4]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[5]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[6]" PULLMODE=DOWN IO_TYPE=LVCMOS33;

LOCATE COMP "led[0]" SITE "B2";
LOCATE COMP "led[1]" SITE "C2";
LOCATE COMP "led[2]" SITE "C1";
LOCATE COMP "led[3]" SITE "D2";
LOCATE COMP "led[4]" SITE "D1";
LOCATE COMP "led[5]" SITE "E2";
LOCATE COMP "led[6]" SITE "E1";
LOCATE COMP "led[7]" SITE "H3";
IOBUF PORT "led[0]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[1]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[2]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[3]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[4]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[5]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[6]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[7]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;

# FPGA -> FTDI -> PC serial (115200 8N1)
LOCATE COMP "ftdi_rxd" SITE "L4";
IOBUF  PORT "ftdi_rxd" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
# PC -> FTDI -> FPGA (flash-writer commands)
LOCATE COMP "ftdi_txd" SITE "M1";
IOBUF  PORT "ftdi_txd" PULLMODE=UP IO_TYPE=LVCMOS33;

# J1 header GP/GN 0-3 (single-ended, BANK0)
LOCATE COMP "pmod_gp[0]" SITE "B11";
LOCATE COMP "pmod_gp[1]" SITE "A10";
LOCATE COMP "pmod_gp[2]" SITE "A9";
LOCATE COMP "pmod_gp[3]" SITE "B9";
LOCATE COMP "pmod_gn[0]" SITE "C11";
LOCATE COMP "pmod_gn[1]" SITE "A11";
LOCATE COMP "pmod_gn[2]" SITE "B10";
LOCATE COMP "pmod_gn[3]" SITE "C10";
IOBUF PORT "pmod_gp[0]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gp[1]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gp[2]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gp[3]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[0]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[1]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[2]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[3]" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;

# keep the ESP32 booted (it can power-cycle the board otherwise)
LOCATE COMP "wifi_gpio0" SITE "L2";
IOBUF  PORT "wifi_gpio0" PULLMODE=UP IO_TYPE=LVCMOS33;
